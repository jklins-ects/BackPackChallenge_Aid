MONGO_URI=mongodb://127.0.0.1:27017
DB_NAME=backpack_challenge
COLLECTION_NAME=participants
ACTIVITY_EVENTS_COLLECTION_NAME=activityEvents
PORT=3000
PUBLIC_API_URL=http://localhost:3000

# Session + web admin auth
SESSION_SECRET=replace-with-long-random-session-secret
AZURE_CLIENT_ID=replace-with-entra-app-client-id
AZURE_CLIENT_SECRET=replace-with-entra-app-client-secret
AZURE_TENANT_ID=replace-with-entra-tenant-id
AZURE_REDIRECT_URI=http://localhost:3000/auth/redirect
AZURE_POST_LOGOUT_REDIRECT_URI=http://localhost:3000/signed-out

# Optional web admin allowlists
ADMIN_ALLOWED_EMAILS=
ADMIN_ALLOWED_DOMAINS=

# Desktop/station API access
STATION_API_KEYS=replace-with-one-or-more-station-api-keys
